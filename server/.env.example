# Backend environment variables (Render Dashboard or local shell)
# NEVER commit real credentials to git.

# Database (Render PostgreSQL)
# ConnectionStrings__DefaultConnection=Host=YOUR_HOST;Port=5432;Database=swipejobsdb;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# JWT (generate a random 32+ character secret)
# Jwt__Key=your-production-jwt-secret-min-32-chars

# Admin seed (created once if missing)
# Admin__Email=admin@yourdomain.com
# Admin__Password=your-secure-admin-password

# CORS (Netlify frontend + local Vite dev server)
# Cors__AllowedOrigins__0=https://swipejobss.netlify.app
# Cors__AllowedOrigins__1=http://localhost:5173
# Cors__AllowedOrigins__2=http://127.0.0.1:5173

# Optional
# ASPNETCORE_ENVIRONMENT=Production
# Seed__DemoData=false
