# Backend environment variables (Azure App Service or local shell)
# NEVER commit real credentials to git.

# Database (Render PostgreSQL external URL — use in Azure App Service / GitHub secret AZURE_DB_CONNECTION_STRING)
# Host=dpg-XXXX.oregon-postgres.render.com;Port=5432;Database=swipejobsdb;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# JWT (generate a random 32+ character secret)
# Jwt__Key=your-production-jwt-secret-min-32-chars

# Admin seed (created once if missing)
# Admin__Email=admin@yourdomain.com
# Admin__Password=your-secure-admin-password

# CORS (Netlify frontend + deploy previews)
# Cors__AllowedOrigins__0=https://swipejobss.netlify.app
# Cors__AllowedOrigins__1=http://localhost:5173
# Cors__AllowedOrigins__2=http://127.0.0.1:5173

# Optional: set if auto-discovery picks the wrong resource group
# AZURE_RESOURCE_GROUP=your-resource-group-name
# ASPNETCORE_ENVIRONMENT=Production
# ConnectionStrings__DefaultConnection=Host=YOUR_HOST;Port=5432;Database=swipejobsdb;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
# Jwt__Key=your-production-jwt-secret-min-32-chars
# Jwt__Issuer=SwipeJobs
# Jwt__Audience=SwipeJobsClient
# Admin__Email=admin@yourdomain.com
# Admin__Password=your-secure-admin-password
# Cors__AllowedOrigins__0=https://swipejobss.netlify.app
